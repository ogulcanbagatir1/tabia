<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Direct distribution outside the Mac App Store, signed with a
         "Developer ID Application" certificate. -->
    <key>method</key>
    <string>developer-id</string>
    <key>teamID</key>
    <string>4NRG5R2K23</string>
    <key>signingStyle</key>
    <string>manual</string>
    <!-- Team 4NRG5R2K23 has a "Developer ID Application" cert (no "Mac Development" one), so the
         Release config signs manually with Developer ID; export re-signs the same way. Developer ID
         distribution needs no provisioning profiles. Hardened Runtime is enabled in build settings. -->

</dict>
</plist>
