{
  "$description": "Tabia — 'The Annotator' design language. Two modes: readingRoom (light) and nightStudy (dark). All values are final (hi-fi).",

  "color": {
    "readingRoom": {
      "paper":        { "value": "#F4EFE3", "use": "window ground" },
      "paperRaised":  { "value": "#EFE8D6", "use": "cards, review panel, notable-game cards" },
      "chrome":       { "value": "#EDE6D2", "use": "titlebar, status bar, sheet headers" },
      "fieldBg":      { "value": "#F7F1E1", "use": "inputs, eval chips, graph background" },
      "hoverWash":    { "value": "#ECE4CD", "use": "row/list hover, selected row" },
      "selectedMove": { "value": "#E7DDC0", "use": "current move highlight in move list" },
      "trackBg":      { "value": "#E2D8BE", "use": "empty bar/track fills" },
      "hairline":     { "value": "#D9CFB8", "use": "every 1px rule" },
      "borderStrong": { "value": "#B5A98D", "use": "input borders, secondary button borders, W/D/L bar frame" },
      "borderChip":   { "value": "#C9BB9C", "use": "chip/badge borders, segmented borders" },
      "ink":          { "value": "#1C1710", "use": "primary text, filled controls, active segment bg" },
      "ink60":        { "value": "#6B6050", "use": "secondary text" },
      "ink40":        { "value": "#8A7E6B", "use": "captions, section labels" },
      "ink25":        { "value": "#A79A80", "use": "placeholders, faint captions" },
      "redInk":       { "value": "#9E2B25", "use": "THE accent: primary buttons, active tab underline, due counts, review marks, checked controls" },
      "windowBorder": { "value": "#2A2117", "use": "1px window outline" }
    },
    "nightStudy": {
      "night":        { "value": "#1C1811", "use": "window ground" },
      "nightRaised":  { "value": "#241E14", "use": "cards, panels, input bg" },
      "nightChrome":  { "value": "#211C13", "use": "titlebar, status bar, sheet headers" },
      "hoverWash":    { "value": "#241E14", "use": "row hover" },
      "selectedWash": { "value": "#2A2317", "use": "selected row / active card" },
      "selectedMove": { "value": "#3F3624", "use": "current move highlight in move list" },
      "trackBg":      { "value": "#2A2418", "use": "empty bar/track fills" },
      "hairline":     { "value": "#3A3222", "use": "every 1px rule" },
      "borderStrong": { "value": "#4A4130", "use": "input/chip borders, toggle-off bg" },
      "paperText":    { "value": "#EDE6DA", "use": "primary text, filled controls, active segment bg" },
      "paperText90":  { "value": "#D8CFBA", "use": "result chips, bright data text" },
      "paperText80":  { "value": "#C4B99F", "use": "engine PV lines, checkbox labels" },
      "paper60":      { "value": "#A99C82", "use": "secondary text" },
      "paper40":      { "value": "#857A63", "use": "captions, section labels" },
      "paper25":      { "value": "#6B6050", "use": "faintest text, disabled" },
      "redInk":       { "value": "#9E2B25", "use": "primary button fills (same as light)" },
      "redInkRaised": { "value": "#C25048", "use": "accent on dark surfaces: active tab underline, due counts, marks, logo dot" },
      "windowBorder": { "value": "#0A0805", "use": "1px window outline" },
      "deepWell":     { "value": "#0F0C08", "use": "black side of W/D/L bars, eval bar well" }
    },
    "board": {
      "$rule": "The board is paper in BOTH modes — never recolored by the theme.",
      "lightSquare":   { "value": "#F0E6CF" },
      "darkSquare":    { "value": "#A98F6C" },
      "lastMoveLight": { "value": "#E7CF8E" },
      "lastMoveDark":  { "value": "#C3A566" },
      "whitePiece":    { "value": "#FAF5E8", "stroke": "rgba(30,23,14,0.9) 1.2px" },
      "blackPiece":    { "value": "#241C12", "stroke": "rgba(20,15,8,0.5) 1px" },
      "frame": {
        "light": "1px #2A2117, then 4px mat #F7F1E1, then 1px #B5A98D, shadow 0 22px 44px rgba(28,23,16,0.22)",
        "dark":  "1px #0A0805, then 4px mat #241E14, then 1px #4A4130, shadow 0 26px 52px rgba(0,0,0,0.55)"
      }
    },
    "moveQuality": {
      "$note": "First value = light mode, second = dark mode (lifted for contrast).",
      "brilliant":  { "light": "#1E7A5A", "dark": "#3FA97C", "mark": "!!" },
      "best":       { "light": "#4E7A34", "dark": "#8FB35B", "mark": "!" },
      "book":       { "light": "#8A6F4D", "dark": "#B29A73", "mark": "□" },
      "inaccuracy": { "light": "#C08A1E", "dark": "#D9A43C", "mark": "?!" },
      "mistake":    { "light": "#BC5A22", "dark": "#D07A3E", "mark": "?" },
      "blunder":    { "light": "#9E2B25", "dark": "#C4534A", "mark": "??" }
    },
    "semantic": {
      "win":     { "light": "#4E7A34", "dark": "#8FB35B" },
      "loss":    { "light": "#9E2B25", "dark": "#C4534A" },
      "draw":    { "light": "#8A7E6B", "dark": "#A99C82" },
      "warning": { "light": "#C08A1E", "dark": "#D9A43C", "use": "gap badges, indexing, sync-in-progress, deviations" },
      "online":  { "light": "#1E7A5A", "dark": "#3FA97C", "use": "engine-running dot (pulses), connected dot" }
    },
    "wdlBars": {
      "$note": "Win/Draw/Loss stacked bars are monochrome paper-ink, never green/red.",
      "light": { "win": "#F7F1E1", "draw": "#C9BB9C", "loss": "#3A3226", "frame": "#B5A98D" },
      "dark":  { "win": "#EDE6DA", "draw": "#6B6050", "loss": "#0F0C08", "frame": "#4A4130" }
    },
    "trafficLights": { "close": "#D3766A", "minimize": "#D9B36A", "zoom": "#8FAE7F" }
  },

  "typography": {
    "display": {
      "family": "Newsreader",
      "fallbackNative": "New York (macOS system serif)",
      "source": "Google Fonts, OFL — bundle with the app",
      "roles": "screen titles, player names, card titles, body prose, empty-state titles; italic = annotator's commentary voice",
      "weights": [400, 500, 600],
      "sizes": { "windowTitle": 20, "screenTitle": 24, "cardTitle": "15–21", "row": "13.5–15", "bigStat": "30–44", "note": "12.5–15 italic" }
    },
    "label": {
      "family": "Instrument Sans",
      "fallbackNative": "SF Pro",
      "source": "Google Fonts, OFL — bundle with the app",
      "roles": "nav tabs, buttons, section labels, chips — ALWAYS uppercase, ALWAYS letter-spaced; never body text",
      "weights": [600, 700],
      "sizes": { "sectionLabel": "9–10 / +0.14em", "navTab": "11 / +0.12em", "button": "10–11 / +0.10em", "chip": "8.5–9.5 / +0.12em" }
    },
    "data": {
      "family": "Courier Prime",
      "fallbackNative": "SF Mono / Courier",
      "source": "Google Fonts, OFL — bundle with the app",
      "roles": "ALL data: notation (SAN), evals, FEN, counts, dates, ECO codes, status bars, meta captions",
      "weights": [400, 700],
      "sizes": { "san": "12.5–13.5", "eval": 11.5, "caption": "9–10.5", "statusBar": 9.5 }
    }
  },

  "metrics": {
    "window":       { "width": 1440, "height": 900, "radius": 13 },
    "titlebar":     { "height": 47 },
    "statusBar":    { "height": 28, "font": "Courier Prime 9.5px" },
    "sidebarLeft":  { "analysis": 300, "repertoireEditor": 292, "database": 280, "explorerBoardCol": 448 },
    "sidebarRight": { "analysis": 372, "repertoire": 396 },
    "boardSquare":  { "analysisHero": 68, "drill": 64, "explorerPage": 48, "sidePanel": 40 },
    "radii":        { "bar": 4, "chip": 5, "control": 7, "input": 8, "cardSmall": 9, "panel": 11, "card": 12, "window": 13 },
    "hairline":     "always exactly 1px",
    "toggle":       { "width": 36, "height": 21, "knob": 16 },
    "padding":      { "panel": "16–20", "card": "18–22", "sheetSection": "20–22" }
  },

  "rules": [
    "Red ink is a pen, not a paint bucket: one filled-red primary action per screen, max. Everything else is bordered or ink-filled.",
    "The chess board keeps its sepia paper colors in both modes — only the surrounding 'lamp' changes.",
    "If it is data (numbers, notation, dates, FEN, ECO), it is set in the mono font. No exceptions.",
    "Labels are uppercase Instrument Sans with letter-spacing; prose and titles are Newsreader; italic Newsreader = the product's speaking voice.",
    "Depth comes from 1px hairlines and soft shadows — no glassmorphism, no blur, no gradients, no glow.",
    "W/D/L bars are monochrome (paper→ink), never traffic-light colored.",
    "Empty states: one icon (line-drawn, 2px stroke), one Newsreader title, one italic sentence, one action. Never a lecture.",
    "Every screen has the mono status bar at the bottom telling the truth about state (counts, sync time, engine depth)."
  ]
}
